<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme (Dark) -->
    <style name="Theme.PasswordWriter" parent="Theme.PasswordWriter.Dark">
    </style>

    <style name="Theme.PasswordWriter.Dark" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/dark_primary</item>
        <item name="colorOnPrimary">@color/dark_on_surface</item>
        <item name="colorSecondary">@color/dark_secondary</item>
        <item name="android:colorBackground">@color/dark_background</item>
        <item name="colorSurface">@color/dark_surface</item>
        <item name="colorOnSurface">@color/dark_on_surface</item>
        <item name="android:statusBarColor">@color/dark_background</item>
    </style>

    <style name="Theme.PasswordWriter.Light" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/light_primary</item>
        <item name="colorOnPrimary">@color/light_on_surface</item>
        <item name="colorSecondary">@color/light_secondary</item>
        <item name="android:colorBackground">@color/light_background</item>
        <item name="colorSurface">@color/light_surface</item>
        <item name="colorOnSurface">@color/light_on_surface</item>
        <item name="android:statusBarColor">@color/light_background</item>
    </style>

    <style name="Theme.PasswordWriter.Vintage" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">@color/vintage_primary</item>
        <item name="colorOnPrimary">@color/vintage_on_surface</item>
        <item name="colorSecondary">@color/vintage_secondary</item>
        <item name="android:colorBackground">@color/vintage_background</item>
        <item name="colorSurface">@color/vintage_surface</item>
        <item name="colorOnSurface">@color/vintage_on_surface</item>
        <item name="android:statusBarColor">@color/vintage_primary</item>
        <item name="android:windowBackground">@color/vintage_background</item>
    </style>
</resources>
